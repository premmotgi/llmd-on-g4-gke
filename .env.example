# =============================================================================
# Gemma-on-GKE POC — single source of truth for environment variables.
# Copy to `.env` and fill in. Sourced by infra/scripts/provision.sh.
# =============================================================================

# --- GCP project / location -------------------------------------------------
export PROJECT_ID="your-gcp-project"
export REGION="us-central1"               # any region with G4 quota
export ZONE="us-central1-a"               # only used when a zonal nodepool is required

# --- Model -------------------------------------------------------------------
# Default: Gemma 4 E4B Instruction-Tuned (released March 31, 2026).
# Swap to "google/gemma-3n-E4B-it" if you wanted the older Gemma 3n MatFormer.
export MODEL_ID="google/gemma-4-E4B-it"
export MODEL_SHORT_NAME="gemma4-e4b-it"   # used in resource names; no slashes

# --- HuggingFace -------------------------------------------------------------
# Gemma is a gated model — accept the license on HuggingFace once with this account,
# then create a read-token at https://huggingface.co/settings/tokens.
export HF_TOKEN="hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- Machine selection ------------------------------------------------------
# Comma-separated list of G4 machine types to provision nodepools for.
# Available G4 machines (all NVIDIA RTX PRO 6000 Blackwell, 96 GB per GPU):
#   g4-standard-48   = 1× GPU,   48 vCPU,  180 GB RAM
#   g4-standard-96   = 2× GPUs,  96 vCPU,  360 GB RAM
#   g4-standard-192  = 4× GPUs, 192 vCPU,  720 GB RAM
#   g4-standard-384  = 8× GPUs, 384 vCPU, 1440 GB RAM
#
# Pick whichever subset you want to benchmark across. Each entry becomes its
# own nodepool with min-nodes=0 (no cost when idle).
export MACHINE_TYPES="g4-standard-48,g4-standard-96,g4-standard-192,g4-standard-384"

# --- Autoscaling bounds -----------------------------------------------------
# Per-nodepool max nodes. Format: <machine-type>:<max>,<machine-type>:<max>,...
# Any machine in MACHINE_TYPES not listed here uses MAX_NODES_DEFAULT.
# min-nodes is always 0 so you don't pay for idle GPUs.
export MAX_NODES_PER_POOL="g4-standard-48:4,g4-standard-96:2,g4-standard-192:1,g4-standard-384:1"
export MAX_NODES_DEFAULT="1"

# --- Provisioning model -----------------------------------------------------
# "on-demand" | "spot" | "flex-start"
#   on-demand  = standard pricing, no preemption
#   spot       = ~60-80% cheaper, can be preempted (great for benchmarks)
#   flex-start = Dynamic Workload Scheduler, queued provisioning, no standing quota needed
export PROVISIONING_MODE="on-demand"

# --- Cluster naming ----------------------------------------------------------
export CLUSTER_NAME="gemma-poc"
export NAMESPACE_PLAIN="vllm-plain"
export NAMESPACE_LLMD="llm-d"
