# =============================================================================
# Gemma-on-GKE POC — single source of truth for environment variables.
# Copy to `.env` and fill in. Sourced by infra/scripts/provision.sh.
# =============================================================================

# --- GCP project / location -------------------------------------------------
export PROJECT_ID="your-gcp-project"
export REGION="us-central1"               # us-central1 / us-east5 / europe-west4 all have G2 + G4
export ZONE="us-central1-a"               # only used when a zonal nodepool is required

# --- Model -------------------------------------------------------------------
# Default: Gemma 4 E4B Instruction-Tuned (released March 31, 2026).
# Swap to "google/gemma-3n-E4B-it" if you wanted the older Gemma 3n MatFormer.
export MODEL_ID="google/gemma-4-E4B-it"
export MODEL_SHORT_NAME="gemma4-e4b-it"   # used in resource names; no slashes

# --- HuggingFace -------------------------------------------------------------
# Gemma is a gated model — accept the license on HuggingFace once with this account,
# then create a read-token at https://huggingface.co/settings/tokens.
export HF_TOKEN="hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- GPU choice (see README §2) ---------------------------------------------
# "g4" = RTX PRO 6000 Blackwell, 96 GB, sizes 48/96/192/384 vCPU
# "g2" = L4, 24 GB, sizes 4/12/24/48 vCPU
export GPU_FAMILY="g4"

# --- Provisioning model (see README §3) -------------------------------------
# "on-demand" | "spot" | "flex-start"
export PROVISIONING_MODE="on-demand"

# --- Cluster naming ----------------------------------------------------------
export CLUSTER_NAME="gemma-poc"
export NAMESPACE_PLAIN="vllm-plain"
export NAMESPACE_LLMD="llm-d"
